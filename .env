# أخذ القيم من my.telegram.org
API_ID=1234567
API_HASH=your_api_hash_here

# معرف المجموعة المصدر (الأرقام أو @username)
SOURCE_GROUP=-1001234567890

# معرف المجموعة الهدف
TARGET_GROUP=-1009876543210

# تأخير بين الدعوات (بالثواني)
DELAY_MIN=10
DELAY_MAX=30

# عدد الدعوات لكل حساب يومياً
DAILY_LIMIT=50
